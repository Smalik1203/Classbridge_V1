{
  "name": "classbridge-pdf-service",
  "version": "1.0.0",
  "private": true,
  "description": "PDF rendering service for ClassBridge report cards. Uses Puppeteer + Handlebars; deploys to Railway.",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "copy-assets": "node -e \"import('node:fs').then(fs=>fs.cpSync('src/templates/assets','dist/templates/assets',{recursive:true,filter:(s)=>!s.endsWith('.ts')}))\"",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "@types/archiver": "^7.0.0",
    "archiver": "^7.0.1",
    "express": "^4.21.0",
    "handlebars": "^4.7.8",
    "puppeteer": "^23.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
